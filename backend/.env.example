# VenuePulse Environment Configuration
# Copy this to .env and fill in real values.
# SECURITY: .env must be listed in .gitignore — never commit secrets.

# Google AI (Gemini API) — Required for AI concierge
# Get your key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# Google Cloud Project ID — Required for Cloud Run deployment
GOOGLE_CLOUD_PROJECT=your_gcp_project_id_here

# Firebase (path to service account JSON) — Required for push notifications
# Download from Firebase Console > Project Settings > Service Accounts
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# Admin Security — Passkey for admin API endpoints
# Must be a strong, unique value (min 16 characters recommended)
ADMIN_PASSKEY=change_this_to_a_secure_passkey_min_16_chars

# CORS Origins (comma-separated) — Explicit domain list, never use "*"
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Environment — "development" or "production"
# In production: missing GOOGLE_API_KEY or ADMIN_PASSKEY will cause startup failure
ENVIRONMENT=development
